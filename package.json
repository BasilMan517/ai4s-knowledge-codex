{
  "name": "ai4s-knowledge-codex",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "A topic-to-expert AI4S knowledge workbench that turns scientific literature into a grounded Codex-ready research environment.",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:server": "node server/index.js",
    "build": "tsc -b && vite build",
    "start": "node server/index.js",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc -b --pretty false"
  },
  "dependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  }
}
